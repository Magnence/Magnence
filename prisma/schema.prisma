  company      String?
  phone        String?
  service      String   // AI | Software Dev | Web & Mobile | Automation | UI/UX | Branding | Marketing | Video | 3D | Other
  budget       String   // Under ₹1L | ₹1L–5L | ₹5L–20L | ₹20L+ | Prefer not to say
  timeline     String   // ASAP | 1–3 months | 3–6 months | 6+ months
  callTiming   String?  // Preferred call timing window
  message      String
  status       String   @default("new") // new | contacted | qualified | won | lost
  source       String   @default("website") // website | referral | ad
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

// Website — newsletter subscribers
model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  status       String   @default("active") // active | unsubscribed | bounced
  source       String   @default("footer") // footer | contact | popup
  ipAddress    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

// Website — job applications from careers page
model JobApplication {
  id           String   @id @default(cuid())
  fullName     String
  email        String
  phone        String?
  position     String   // job title applied for
  department   String   // Engineering | Design | AI/ML | Marketing | Operations
  experience   String?  // years of experience
  currentCtc   String?  // current CTC
  expectedCtc  String?  // expected CTC
  noticePeriod String?  // notice period
  portfolioUrl String?  // portfolio/LinkedIn URL
  coverLetter  String?  // cover letter / why Magnence
  resumeUrl    String?  // resume file URL (stored path)
  resumeFileName String?
  status       String   @default("new") // new | reviewed | shortlisted | interviewed | offered | rejected
  source       String   @default("website")
  ipAddress    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([position])
  @@index([createdAt])
  @@index([email])
}

// Website — visitor analytics (only collected when cookie consent is given)
model WebsiteAnalytics {
  id           String   @id @default(cuid())
  sessionId    String   // anonymous session ID
  event        String   // page_view | click | scroll | session_start | session_end
  page         String?  // URL path
  referrer     String?  // referrer URL
  userAgent    String?
  ipAddress    String?
  country      String?  // geo-located (optional)
  deviceType   String?  // mobile | tablet | desktop
  browser      String?
  os           String?
  duration     Int?     // time on page in seconds (for session events)
  createdAt    DateTime @default(now())

  @@index([event])
  @@index([createdAt])
  @@index([sessionId])
}

// CMS — Blog posts managed from Magnence OS
model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String
  category      String
  content       String   // JSON array of sections
  authorName    String
  authorRole    String
  authorGradient String
  imageUrl      String?
  imageGradient String
  status        String   @default("draft") // draft | published | archived
  featured      Boolean  @default(false)
  tags          String?  // comma-separated
  seoTitle      String?
  seoDescription String?
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
}

// CMS — Case studies managed from Magnence OS
model CaseStudy {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  category      String
  industry      String
  tagline       String
  resultMetric  String
  description   String
  challenge     String
  approach      String
  solution      String
  results       String   // JSON array of {value, label}
  imageUrl      String?
  imageGradient String
  technologies  String   // comma-separated
  services      String   // comma-separated
  timeline      String
  client        String
  status        String   @default("draft") // draft | published | archived
  featured      Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([industry])
}
