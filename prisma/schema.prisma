// CRM — Companies & Contacts
model Company {
  id          String   @id @default(cuid())
  name        String
  industry    String?
  website     String?
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?
  size        String?  // startup | small | medium | large | enterprise
  revenue     Float    @default(0)
  isClient    Boolean  @default(false)
  clientId    String?  // link to client record if converted
  status      String   @default("lead") // lead | prospect | active_client | inactive
  source      String?  // website | referral | ads | event | cold_outreach
  ownerId     String?  // account manager
  tags        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User?    @relation("OwnedCompanies", fields: [ownerId], references: [id])
  contacts    Contact[]
  deals       Deal[]
  activities  Activity[]
  invoices    Invoice[]  @relation("CompanyInvoices")
  contracts   Contract[] @relation("CompanyContracts")
  quotations  Quotation[]
  proposals   Proposal[]
