// Magnence OS — Phase 1 Foundation Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ AUTH & IDENTITY ============

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String?
  name            String
  avatarColor     String   @default("#f1c24e")
  role            String   @default("EMPLOYEE") // one of ROLE_TYPES
  customRole      String?  // user-defined role id (Role.id)
  department      String   @default("General")
  title           String?
  phone           String?
  location        String?
  bio             String?
  status          String   @default("active") // active | away | offline | suspended | archived
  emailVerified   Boolean  @default(false)
  mfaEnabled      Boolean  @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions        Session[]
  ticketsOpened   Ticket[]  @relation("OpenedBy")
  ticketsAssigned Ticket[]  @relation("AssignedTo")
  chatSessions    ChatSession[]
  socialPosts     SocialPost[]
  activityLogs    ActivityLog[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  announcements   Announcement[] @relation("AnnouncementAuthor")
  calendarEvents  CalendarEvent[] @relation("EventOrganizer")
  eventAttendees  EventAttendee[]
  documents       Document[] @relation("DocumentOwner")
  documentUploads DocumentVersion[] @relation("DocumentUploader")
  approvals       Approval[]  @relation("ApprovalApprover")
  employees       EmployeeProfile[]
  teamMemberships TeamMember[]
  teamLeadOf      Team[]      @relation("TeamLead")
  deptHeadOf      Department[] @relation("DeptHead")
  leaveBalances   LeaveBalance[]
  leaves          Leave[]     @relation("LeaveRequester")
  leaveApprover   Leave[]     @relation("LeaveApprover")
  kbAuthor        KnowledgeBase[] @relation("KbAuthor")
  kbApprover      KnowledgeBase[] @relation("KbApprover")

  // Phase 2 relations
  tasksAssigned   Task[]     @relation("TaskAssignee")
  tasksReported   Task[]     @relation("TaskReporter")
  taskComments    TaskComment[]
  timeEntries     TimeEntry[]
  attendance      Attendance[]
  meetingsOrganized Meeting[] @relation("MeetingOrganizer")
  meetingInvites  MeetingAttendee[]
  notes           Note[]
  goals           Goal[]
  assetsAssigned  Asset[]    @relation("AssetAssignedTo")

  // Phase 3 relations
  expenses        Expense[]
  callLogs        CallLog[]
  emailLogs       EmailLog[]
  ownedCompanies  Company[]  @relation("OwnedCompanies")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  device       String?  // browser + os fingerprint
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============ ORG STRUCTURE ============

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  headId      String?
  parentId    String?  // for hierarchy
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  head        User?    @relation("DeptHead", fields: [headId], references: [id])
  parent      Department? @relation("DeptChildren", fields: [parentId], references: [id])
  children    Department[] @relation("DeptChildren")
  teams       Team[]
  employees   EmployeeProfile[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  departmentId String?
  leadId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  department  Department? @relation(fields: [departmentId], references: [id])
  lead        User?    @relation("TeamLead", fields: [leadId], references: [id])
  members     TeamMember[]
  employees   EmployeeProfile[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("member") // lead | member
  joinedAt  DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Designation {
  id        String   @id @default(cuid())
  name      String
  level     Int      @default(1)
  reportsToId String? // self-reference for reporting structure
  createdAt DateTime @default(now())
  reportsTo Designation? @relation("DesignationReportsTo", fields: [reportsToId], references: [id])
  children  Designation[] @relation("DesignationReportsTo")
}

model Office {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  country   String?
  timezone  String?
  workStart String?  // "09:00"
  workEnd   String?  // "18:00"
  workDays  String?  // "mon,tue,wed,thu,fri"
  remote    Boolean  @default(false)
  hybrid    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CompanySettings {
  id            String   @id @default(cuid()) @unique
  name          String   @default("Magnence")
  logo          String?
  primaryColor  String   @default("#f1c24e")
  timezone      String   @default("Asia/Kolkata")
  currency      String   @default("INR")
  language      String   @default("en")
  fiscalYearStart String? // "April"
  workingHours  String?  // "9-18"
  branding      String?  // JSON for advanced brand config
  updatedAt     DateTime @updatedAt
}

// ============ EMPLOYEES ============

model EmployeeProfile {
  id           String   @id @default(cuid())
  userId       String
  employeeCode String?  // e.g. MAG-001
  joinDate     DateTime?
  employmentStatus String? @default("active") // active | on_leave | notice | archived
  departmentId String?
  teamId       String?
  managerId    String?
  designation  String?
  level        Int      @default(1)
  skills       String?  // comma-separated
  experience   String?  // JSON
  education    String?  // JSON
  documents    String?  // JSON of file URLs
  emergencyContact String? // JSON
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  team         Team?    @relation(fields: [teamId], references: [id])
  leaves       Leave[]
  leaveBalances LeaveBalance[]
}

model LeaveBalance {
  id           String   @id @default(cuid())
  employeeId   String
  userId       String
  year         Int
  type         String   // sick | casual | earned | unpaid
  balance      Float    @default(0)
  used         Float    @default(0)
  employee     EmployeeProfile @relation(fields: [employeeId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
}

model Leave {
  id          String   @id @default(cuid())
  employeeId  String
  userId      String
  approverId  String?
  type        String   // sick | casual | earned | unpaid
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      String   @default("pending") // pending | approved | rejected
  createdAt   DateTime @default(now())
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id])
  user        User     @relation("LeaveRequester", fields: [userId], references: [id])
  approver    User?    @relation("LeaveApprover", fields: [approverId], references: [id])
}

// ============ ROLES & PERMISSIONS ============

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) // system roles can't be deleted
  permissions String   @default("{}") // JSON of permission keys
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ SUPPORT ============

model Ticket {
  id          String        @id @default(cuid())
  title       String
  description String
  category    String        // bug | feature | technical | account | access | security | feedback | complaint | general
  priority    String        @default("medium")
  status      String        @default("new") // new | open | assigned | in_progress | waiting | escalated | resolved | closed
  openedById  String
  assignedToId String?
  department  String?
  response    String?
  tags        String?
  dueDate     DateTime?
  attachments String?       // JSON array of {name, size, type, url}
  aiSuggested String?       // JSON {category, priority, solution}
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  resolvedAt  DateTime?
  openedBy    User          @relation("OpenedBy", fields: [openedById], references: [id])
  assignedTo  User?         @relation("AssignedTo", fields: [assignedToId], references: [id])
  messages    TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  authorName String
  content   String
  isStaff   Boolean  @default(false)
  isAi      Boolean  @default(false)
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
}

// ============ KNOWLEDGE BASE ============

model KnowledgeBase {
  id         String   @id @default(cuid())
  title      String
  category   String   // sop | policy | hr | technical | marketing | sales | finance | legal | training | faq
  department String?
  content    String
  tags       String?
  version    Int      @default(1)
  status     String   @default("draft") // draft | pending_review | published | archived
  authorId   String?
  approverId String?
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  publishedAt DateTime?
  attachments String?
  revisions  KnowledgeRevision[]
  author     User?    @relation("KbAuthor", fields: [authorId], references: [id])
  approver   User?    @relation("KbApprover", fields: [approverId], references: [id])
}

model KnowledgeRevision {
  id         String   @id @default(cuid())
  articleId  String
  version    Int
  content    String
  authorId   String?
  changeNote String?
  createdAt  DateTime @default(now())
  article    KnowledgeBase @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Approval {
  id          String   @id @default(cuid())
  type        String   // knowledge | document | leave | custom
  entityId    String
  requesterId String?
  approverId  String?
  status      String   @default("pending") // pending | approved | rejected
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  approver    User?    @relation("ApprovalApprover", fields: [approverId], references: [id])
}

// ============ CHAT / AI ============

model ChatSession {
  id         String   @id @default(cuid())
  userId     String
  agentType  String
  title      String?
  summary    String?
  context    String?  // JSON {module, page, role, dept}
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  messages   ChatMessage[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String
  content    String
  action     String?  // if AI generated email/report/etc
  createdAt  DateTime @default(now())
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ============ DOCUMENTS ============

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String   // file | folder
  mimeType    String?
  size        Int      @default(0)
  url         String?
  parentId    String?  // for nested folders
  ownerId     String
  permissions String?  // JSON {view:[], edit:[], delete:[]}
  isShared    Boolean  @default(false)
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation("DocumentOwner", fields: [ownerId], references: [id])
  versions    DocumentVersion[]
  children    Document[] @relation("DocChildren")
  parent      Document?  @relation("DocChildren", fields: [parentId], references: [id])
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    Int
  url        String?
  size       Int      @default(0)
  uploadedById String?
  note       String?
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation("DocumentUploader", fields: [uploadedById], references: [id])
}

// ============ MARKETING / SALES / SOCIAL ============

model Campaign {
  id         String   @id @default(cuid())
  name       String
  channel    String
  status     String   @default("planned")
  budget     Float    @default(0)
  spent      Float    @default(0)
  leads      Int      @default(0)
  conversions Int     @default(0)
  revenue    Float    @default(0)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lead {
  id         String   @id @default(cuid())
  name       String
  email      String?
  company    String?
  source     String
  stage      String   @default("new")
  value      Float    @default(0)
  ownerId    String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SocialPost {
  id         String   @id @default(cuid())
  platform   String
  content    String
  status     String   @default("draft")
  scheduledAt DateTime?
  publishedAt DateTime?
  likes      Int      @default(0)
  comments   Int      @default(0)
  shares     Int      @default(0)
  reach      Int      @default(0)
  impressions Int     @default(0)
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id])
}

model SocialAccount {
  id         String   @id @default(cuid())
  platform   String
  handle     String
  followers  Int      @default(0)
  following  Int      @default(0)
  posts      Int      @default(0)
  engagement Float    @default(0)
  connected  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // ticket | announcement | assignment | approval | mention | ai | system
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  inApp     String   @default("{}") // JSON of type: bool
  email     String   @default("{}")
  push      String   @default("{}")
  muted     Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// ============ ANNOUNCEMENTS ============

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  category    String   @default("company") // company | department | hr | holiday | event | maintenance | emergency
  audience    String   @default("all")     // all | department:ID | role:NAME
  authorId    String
  pinned      Boolean  @default(false)
  scheduledAt DateTime?
  expiresAt   DateTime?
  attachments String?
  readBy      String?  // JSON array of userIds
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation("AnnouncementAuthor", fields: [authorId], references: [id])
}

// ============ CALENDAR ============

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   // meeting | holiday | company_event | birthday | anniversary | deadline
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean  @default(false)
  location    String?
  organizerId String?
  audience    String   @default("all")
  recurrence  String?  // none | daily | weekly | monthly | yearly
  reminder    Int?     // minutes before
  createdAt   DateTime @default(now())
  organizer   User?    @relation("EventOrganizer", fields: [organizerId], references: [id])
  attendees   EventAttendee[]
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String   @default("invited") // invited | accepted | declined | tentative
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

// ============ LOGS ============

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  target     String?
  meta       String?
  category   String   @default("user") // user | file | support | document | permission | admin | ai
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // login | logout | permission_change | config_change | data_export | system_event
  category   String   @default("security") // security | auth | permission | config | data | system
  target     String?
  ipAddress  String?
  userAgent  String?
  meta       String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

// ============ PHASE 2: PRODUCTIVITY & WORK MANAGEMENT ============

// Tasks
model Task {
  id            String   @id @default(cuid())
  title         String
  description   String?
  status        String   @default("todo") // todo | in_progress | review | qa | approved | completed | cancelled | reopened
  priority      String   @default("medium") // low | medium | high | urgent
  dueDate       DateTime?
  startDate     DateTime?
  estimatedTime Int?     // minutes
  actualTime    Int      @default(0) // minutes
  department    String?
  projectId     String?
  assigneeId    String?
  reporterId    String?
  labels        String?  // comma-separated
  tags          String?
  checklist     String?  // JSON [{text, done}]
  parentTaskId  String?
  watchers      String?  // JSON user IDs
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedAt   DateTime?

  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee      User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter      User?    @relation("TaskReporter", fields: [reporterId], references: [id])
  comments      TaskComment[]
  timeEntries   TimeEntry[]
  subtasks      Task[]   @relation("TaskSubtasks")
  parentTask    Task?    @relation("TaskSubtasks", fields: [parentTaskId], references: [id])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  mentions  String?  // JSON user IDs
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// Projects
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("internal") // internal | client
  department  String?
  teamId      String?
  clientId    String?
  status      String   @default("planning") // planning | active | on_hold | completed | cancelled
  budget      Float    @default(0)
  spent       Float    @default(0)
  progress    Int      @default(0) // percentage
  startDate   DateTime?
  endDate     DateTime?
  objectives  String?
  deliverables String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
  milestones  Milestone[]
  timeEntries TimeEntry[]
}

model Milestone {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Time tracking
model TimeEntry {
  id        String   @id @default(cuid())
  userId    String
  taskId    String?
  projectId String?
  startTime DateTime
  endTime   DateTime?
  duration  Int      @default(0) // minutes
  billable  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// Attendance
model Attendance {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  workMinutes Int    @default(0)
  breakMinutes Int   @default(0)
  overtimeMinutes Int @default(0)
  status    String   @default("pending") // present | absent | late | half_day | pending
  shift     String   @default("day") // day | night | flexible
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Meetings
model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  agenda      String?
  organizerId String
  startTime   DateTime
  endTime     DateTime
  location    String?
  recordingUrl String?
  notes       String?
  aiSummary   String?
  actionItems String?  // JSON array
  status      String   @default("scheduled") // scheduled | completed | cancelled
  createdAt   DateTime @default(now())
  organizer   User     @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  attendees   MeetingAttendee[]
}

model MeetingAttendee {
  id         String   @id @default(cuid())
  meetingId  String
  userId     String
  status     String   @default("invited") // invited | accepted | declined | tentative
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
}

// Notes
model Note {
  id         String   @id @default(cuid())
  title      String
  content    String
  category   String   @default("personal") // personal | shared | team | meeting
  authorId   String
  tags       String?
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// Goals & KPIs
model Goal {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("individual") // individual | team | department | company
  ownerId     String
  progress    Int      @default(0) // percentage
  status      String   @default("active") // active | completed | paused | cancelled
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  owner       User     @relation(fields: [ownerId], references: [id])
  kpis        Kpi[]
}

model Kpi {
  id         String   @id @default(cuid())
  goalId     String?
  title      String
  target     Float
  current    Float    @default(0)
  unit       String?  // % | $ | count
  ownerId    String
  createdAt  DateTime @default(now())
  goal       Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)
}

// Internal chat
model Channel {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("team") // direct | team | department | project | group
  members    String?  // JSON user IDs
  createdAt  DateTime @default(now())
  messages   ChannelMessage[]
}

model ChannelMessage {
  id         String   @id @default(cuid())
  channelId  String
  authorId   String
  authorName String
  content    String
  mentions   String?
  createdAt  DateTime @default(now())
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

// Forms
model Form {
  id           String   @id @default(cuid())
  title        String
  description  String?
  category     String   @default("custom") // leave | expense | asset | access | travel | purchase | custom
  fields       String   @default("[]") // JSON field defs
  workflow     String?  // JSON approval steps
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  submissions  FormSubmission[]
}

model FormSubmission {
  id         String   @id @default(cuid())
  formId     String
  submittedBy String
  data       String   @default("{}") // JSON
  status     String   @default("pending") // pending | approved | rejected
  createdAt  DateTime @default(now())
  form       Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
}

// Assets / Resources
model Asset {
  id         String   @id @default(cuid())
  name       String
  type       String   // laptop | monitor | phone | keyboard | chair | other
  serial     String?
  assignedToId String?
  status     String   @default("available") // available | assigned | in_repair | retired
  purchaseDate DateTime?
  value      Float    @default(0)
  createdAt  DateTime @default(now())
